{
  "name": "change-evidence",
  "version": "0.1.1",
  "description": "Local pre-commit risk summaries for AI-assisted code changes.",
  "type": "module",
  "bin": {
    "change-evidence": "dist/cli/index.js",
    "ce": "dist/cli/index.js"
  },
  "types": "dist/api/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "files": [
    "dist/",
    "assets/",
    "install.sh",
    "scripts/postinstall.cjs",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:api",
    "build:cli": "tsup src/cli/index.ts --format esm --dts --clean --out-dir dist/cli",
    "build:api": "tsup src/api/index.ts --format esm --dts --clean --out-dir dist/api",
    "build:plugins": "sh scripts/build-plugins.sh",
    "dev": "tsx src/cli/index.ts",
    "postinstall": "node scripts/postinstall.cjs",
    "prepare": "npm run build",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "git",
    "diff",
    "cli",
    "pre-commit",
    "ai-coding",
    "risk-report",
    "change-evidence"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qcodingdev/change-evidence.git"
  },
  "bugs": {
    "url": "https://github.com/qcodingdev/change-evidence/issues"
  },
  "homepage": "https://github.com/qcodingdev/change-evidence#readme",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "vite": "^6.4.3"
  }
}
